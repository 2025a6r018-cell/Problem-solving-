#include<stdio.h>
#include<stdlib.h>
int partition(int *arr, int start, int end){
    int idx = start-1,pivat = arr[end];
    for(int j = start; j<end; j++){
        if(arr[j] <= pivat){
            idx++;
            int temp = arr[j];
            arr[j] = arr[idx];
            arr[idx] = temp;
        }
    }
    idx++;
     int temp = arr[end];
     arr[end] = arr[idx];
     arr[idx] = temp;
     return idx;
    
}
void Quicksort(int *arr, int start, int end){
    if(start < end){
    int pivat = partition(arr, start, end);
    Quicksort (arr, start, pivat-1);
    Quicksort(arr, pivat+1, end);
    }
}    

int main(){
    int n;
    printf("Enter Array Size:");
    scanf("%d", &n);
    int arr[n];
    printf("Enter Array Elements:");
    for(int i=0; i<n ; i++)
        scanf("%d", &arr[i]);
        Quicksort(arr, 0, n-1);
    printf("After Sorting Array Elements are: ");
    for(int i=0; i<n ; i++){
        printf("%d ", arr[i]);
    }
    return 0;
}


