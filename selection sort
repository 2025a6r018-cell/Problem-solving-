 #include<stdio.h>
#include<stdlib.h>
int main(){
    int n;
    printf("Enter Array Size: ");
    scanf("%d", &n);
    int arr[n];
    printf("Enter Array Elements: ");
    for(int i=0; i<n ; i++)
        scanf("%d", &arr[i]);
    // selection sort
    for(int i=0; i<n-1 ; i++){
        int minIdx = i;
        for(int j = i+1; j<n; j++){
        if(arr[j] < arr[minIdx])
        minIdx = j;
    }
    if(minIdx != i){
        int temp = arr[i];
        arr[minIdx] = arr[i];
        arr[i] = temp;
    }
}

    printf("After Sorting Elements are:");
    for(int i=0; i<n; i++){
        printf("%d", arr[i]);
    }
    return 0;
}

    
