#include<stdio.h>
#include<stdlib.h>
int main(){
    int n;
    printf("Enter Array Size: ");
    scanf("%d", &n);
    int arr[n];
    printf("Enter Array Elements: ");
    for(int i=0; i<n ; i++)
        scanf("%d", &arr[i]);
    int val;
    printf("Enter Searching Element: ");
    scanf("%d", &val);
    // Binary Search Logic
    int startIdx = 0, endIdx = n-1;
    while(startIdx <= endIdx){
        int mid = startIdx + (endIdx - startIdx)/2;
        if(val == arr[mid]){
            printf("Found !!!\n");
            return 0;
        }
        else if(val < arr[mid])
        endIdx = mid -1;
        else
        startIdx = mid + 1;
    }
      printf("Not Found !!!\n");
      return 0;
    
    
}

